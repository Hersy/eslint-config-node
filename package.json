{
  "name": "@hersy/eslint-config-node",
  "version": "1.0.0",
  "description": "A modern ESLint configuration for NodeJS, following my styleguide",
  "keywords": [
    "config",
    "hersy",
    "eslint",
    "eslintconfig",
    "javascript",
    "typescript",
    "node",
    "styleguide"
  ],
  "homepage": "https://github.com/hersy/eslint-config-node",
  "bugs": {
    "url": "https://github.com/hersy/eslint-config-node/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/hersy/eslint-config-node"
  },
  "license": "MIT",
  "author": "Santiago 'Hersy' Heilborn <contact@hersy.dev>",
  "exports": {
    ".": {
      "import": "./lib/esm/index.js",
      "require": "./lib/cjs/index.js"
    }
  },
  "files": [
    "lib",
    "README.md",
    "LICENSE"
  ],
  "main": "index.js",
  "scripts": {
    "lint": "eslint .",
    "lint-fix": "eslint --fix .",
    "eslint-check": "eslint --print-config ./index.js",
    "pretests-only": "node ./test/imports",
    "pretest": "npm run --silent pretests-only",
    "tests-only": "babel-tape-runner ./test/test-*.js",
    "test": "npm run --silent tests-only",
    "prepublishOnly": "eslint-find-rules --unused ./index.js --flat-config",
    "prepublish": "not-in-publish || npm run prepublishOnly"
  },
  "dependencies": {
    "@eslint/css": "^0.7.0",
    "@eslint/js": "^9.0.0",
    "@eslint/json": "^0.12.0",
    "@eslint/markdown": "^6.0.0",
    "@html-eslint/eslint-plugin": "^0.40.0",
    "@html-eslint/parser": "^0.40.0",
    "@microsoft/eslint-plugin-sdl": "^1.0.0",
    "@stylistic/eslint-plugin": "^4.0.0",
    "eslint-import-resolver-typescript": "^4.0.0",
    "eslint-plugin-eslint-comments": "^3.0.0",
    "eslint-plugin-import": "^2.0.0",
    "eslint-plugin-import-name": "^1.0.0",
    "eslint-plugin-jsdoc": "^50.0.0",
    "eslint-plugin-n": "^17.0.0",
    "eslint-plugin-promise": "^7.0.0",
    "eslint-plugin-regexp": "^2.0.0",
    "eslint-plugin-security": "^3.0.0",
    "eslint-plugin-sonarjs": "^3.0.0",
    "eslint-plugin-unicorn": "^58.0.0",
    "eslint-plugin-unused-imports": "^4.0.0",
    "globals": "^16.0.0",
    "typescript-eslint": "^8.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.27.0",
    "@babel/runtime": "^7.27.0",
    "@hersy/babel-preset": "^0.2.0",
    "@hersy/babel-tape-runner": "^1.0.0",
    "@types/node": "^22.15.0",
    "eslint": "^9.26.0",
    "eslint-find-rules": "^5.0.0",
    "in-publish": "^2.0.0",
    "tape": "^5.9.0",
    "typescript": "^5.8.0"
  },
  "peerDependencies": {
    "eslint": "^9.0.0"
  },
  "overrides": {
    "glob": "^9.0.0",
    "rimraf": "^6.0.0"
  }
}